{
  "name": "pw-api-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright API test automation framework — TypeScript, AJV schema validation, GitHub Actions CI",
  "scripts": {
    "test": "playwright test",
    "test:verbose": "cross-env API_LOG=verbose playwright test",
    "test:grep": "playwright test --grep",
    "test:verbose:grep": "cross-env API_LOG=verbose playwright test --grep",
    "test:verbose:smoke": "cross-env API_LOG=verbose playwright test --grep @smoke",
    "test:verbose:articles": "cross-env API_LOG=verbose playwright test --grep @articles",
    "test:schema": "playwright test --grep @schema",
    "test:verbose:schema": "cross-env API_LOG=verbose playwright test --grep @schema",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "har:filter": "npx tsx tools/harFilter.ts",
    "docker:build": "docker compose build",
    "docker:test": "docker compose run --rm tests",
    "docker:test:verbose": "docker compose run --rm -e API_LOG=verbose tests",
    "docker:test:smoke": "docker compose run --rm tests npx playwright test --grep @smoke",
    "docker:test:schema": "docker compose run --rm tests npx playwright test --grep @schema",
    "prepare": "husky"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "typescript",
    "test-automation"
  ],
  "author": "Maksim Tarasov",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-playwright": "^2.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
